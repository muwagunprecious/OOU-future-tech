{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "server/index.js": {
      "includeFiles": ".env",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
